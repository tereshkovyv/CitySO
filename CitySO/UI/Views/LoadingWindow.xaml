<Window x:Class="CitySO.UI.Views.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Загрузка" Height="150" Width="200"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Opacity="0.9">
    <Grid>
        <Border Background="#1E293B" CornerRadius="8" Padding="20">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="100" Height="20" Foreground="#60A5FA" Background="#334155"/>
                <TextBlock Text="Загрузка..." Foreground="#F1F5F9" FontSize="14" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>